{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product sold in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["pipa", "linha", "rabiola", "acessorio"] },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "category", "price", "cost", "stock", "minStock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A completed sale transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["dinheiro", "cartao_credito", "cartao_debito", "pix"] },
        "timestamp": { "type": "number" },
        "profit": { "type": "number" },
        "uid": { "type": "string", "description": "UID of the user who made the sale" }
      },
      "required": ["items", "total", "paymentMethod", "timestamp", "profit", "uid"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["receita", "despesa"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "number" },
        "uid": { "type": "string", "description": "UID of the user who recorded the transaction" }
      },
      "required": ["type", "amount", "description", "category", "timestamp", "uid"]
    },
    "User": {
      "title": "User",
      "description": "User profile and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of sales"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of financial transactions"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
